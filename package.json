    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
